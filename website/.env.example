# Copy to `.env.local` (gitignored). Next.js loads it at build time.

# GA4 → Admin → Data streams → Web → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Ads → Tools → Data manager / tag setup → รูปแบบ AW-xxxxxxxxxx
NEXT_PUBLIC_GOOGLE_ADS_TAG_ID=AW-XXXXXXXXXX

# เป้าหมายการแปลง (เว็บไซต์) แยก Play / iOS — รูปแบบ AW-xxxxxxxxx/LABEL จาก Google Ads
# ไม่ใส่ = ยังยิง event `store_outbound_click` ใน GA4 ได้ แต่ไม่นับเป็น Ads conversion
NEXT_PUBLIC_GOOGLE_ADS_CONV_PLAY_STORE=AW-18017791527/xxxxxxxx
NEXT_PUBLIC_GOOGLE_ADS_CONV_APP_STORE=AW-18017791527/yyyyyyyy
