# Copy to .env.local and fill in values.

# Auth.js — session signing (openssl rand -base64 32)
AUTH_SECRET=
# NEXTAUTH_SECRET=   # legacy alias; optional if AUTH_SECRET is set

# Public URL of this app. On localhost MUST match browser origin (scheme + host + port).
NEXTAUTH_URL=http://localhost:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated; must include the Google account you sign in with
ALLOWED_ADMIN_EMAILS=you@example.com

# Localhost Google OAuth checklist: see LOCALHOST_GOOGLE_OAUTH.md
#
# Production (Cloud Run): see CLOUD_RUN.md and ./deploy.sh

# --- Firebase Admin (Firestore API routes) ---
# Option A: paste service account fields from GCP (same as Cloud Run secrets)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Use real newlines or \n in one line
FIREBASE_PRIVATE_KEY=
# Option B: download JSON from Firebase Console → Project settings → Service accounts
# and save as serviceAccountKey.json in this folder (admin-panel/) — no need for the three vars above
#
# Offer "Translate" button on the same GCP project:
# 1) Enable API: https://console.cloud.google.com/apis/library/translate.googleapis.com
# 2) IAM → service account (same as FIREBASE_CLIENT_EMAIL) → add role
#    "Cloud Translation API User" (roles/cloudtranslate.user)
